# HyperDeck FTP-to-S3/Local Configuration
# Copy to .env and fill in values

# === FTP (HyperDeck) ===
HDFS_FTP_HOST=192.168.1.100        # HyperDeck IP address (required)
HDFS_FTP_PORT=21                    # FTP port (default: 21)
HDFS_FTP_USER=anonymous             # FTP username (default: anonymous)
HDFS_FTP_PASSWORD=                  # FTP password (default: empty)
HDFS_FTP_TIMEOUT=30000              # Control socket timeout in ms (default: 30000)
HDFS_FTP_KEEPALIVE=10000            # NOOP keepalive interval in ms (default: 10000)

# === Transfer Destination ===
HDFS_DESTINATION=s3                 # "s3" or "local" (default: s3)

# === S3 Storage (used when HDFS_DESTINATION=s3) ===
HDFS_S3_BUCKET=my-video-bucket      # Target bucket (required for s3)
HDFS_S3_KEY_PREFIX=                  # Object key prefix/folder (default: empty)
HDFS_S3_REGION=us-east-1            # Region (default: us-east-1)
HDFS_S3_ENDPOINT=                   # Custom endpoint URL (required for B2/R2/e2)
HDFS_S3_ACCESS_KEY_ID=              # Access key (falls back to AWS credential chain)
HDFS_S3_SECRET_ACCESS_KEY=          # Secret key (falls back to AWS credential chain)
HDFS_S3_FORCE_PATH_STYLE=false      # Path-style URLs (required for Backblaze B2)

# === S3 Transfer Settings ===
HDFS_S3_PART_SIZE=104857600         # Multipart part size in bytes (default: 100MB)
HDFS_S3_MAX_RETRIES=3               # Part-level retry count (default: 3)
HDFS_S3_CONCURRENCY=1               # Concurrent part uploads (default: 1)

# === Local/UNC Storage (used when HDFS_DESTINATION=local) ===
HDFS_FS_OUTPUT_DIR=                 # Output directory (required for local). Examples:
                                    #   D:\footage
                                    #   \\server\share\footage
                                    #   /mnt/nas/footage
HDFS_FS_PART_SIZE=26214400          # Part staging size in bytes (default: 25MB)
HDFS_FS_MAX_RETRIES=3               # Retries per part write (default: 3)
HDFS_FS_CONCURRENCY=4               # Concurrent part writes (default: 4)

# === General Settings ===
HDFS_HIGH_WATER_MARK=1048576        # Stream buffer size in bytes (default: 1MB)
HDFS_STATE_DIR=./state              # Transfer state directory (default: ./state)
HDFS_PROGRESS_INTERVAL=5000         # Progress log interval in ms (default: 5000)
HDFS_LOG_LEVEL=INFO                 # Minimum log level: DEBUG, INFO, WARN, ERROR, FATAL
HDFS_LOG_MAX_SIZE=10485760          # Max log file size in bytes before truncation (default: 10MB)

# === HyperDeck (optional, for clip discovery) ===
HDFS_HYPERDECK_HOST=                # HyperDeck IP for TCP 9993 protocol

# === Provider Endpoint Examples ===
# AWS S3:       (omit HDFS_S3_ENDPOINT, uses default)
# Backblaze B2: HDFS_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com  HDFS_S3_FORCE_PATH_STYLE=true
# Cloudflare R2: HDFS_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# iDrive e2:   HDFS_S3_ENDPOINT=https://<region>.e2.idrivesync.com
