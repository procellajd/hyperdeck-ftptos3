{
  "name": "hyperdeck-ftptos3",
  "version": "1.0.0",
  "description": "Stream files from Blackmagic HyperDeck FTP directly to S3-compatible storage via multipart upload with zero local disk usage",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "record2s3": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --format=cjs --target=node20 --minify --tree-shaking=true --outfile=dist/bundle.cjs",
    "exe": "node scripts/build-exe.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@smithy/node-http-handler": "^4.0.0",
    "basic-ftp": "^5.0.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
